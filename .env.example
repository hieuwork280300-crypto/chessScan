# Copy to .env and fill in. EXPO_PUBLIC_* values are embedded in the JS bundle at build time.
# (v1 ships keys client-side; proxy sensitive ones through a backend in v2.)

EXPO_PUBLIC_GEMINI_API_KEY=

# RevenueCat public SDK keys (from RevenueCat dashboard → Project → API keys).
# IAP only runs on an EAS dev/prod build, NOT in Expo Go. Leave blank to use the local stub.
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=
